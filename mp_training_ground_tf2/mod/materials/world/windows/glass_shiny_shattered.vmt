"LightmappedGeneric"
{
	// ARTIST TWEAKABLES

	// TF2_UNSUPPORTED $detailcolor: "$detailcolor" "world\windows\glass_shattered_tempered_col"
	// TF2_UNSUPPORTED $detailcolormode: "$detailcolormode" 1
	// TF2_UNSUPPORTED $detailnormal: "$detailnormal" "world\windows\glass_shattered_tempered_nml"
	// TF2_UNSUPPORTED $detailnormalmode: "$detailnormalmode" 1
	// TF2_UNSUPPORTED $detailscale: "$detailscale" "[2 2]"

	"$color2" "[.61 .66 .64]"
	"$alpha" ".5"



	// NON-TWEAKABLES

	// Can't tweak these because the UVs are being used for masking edges and the texture is overridden.
	"$basetexture" "effects/white"
	// TF2_UNSUPPORTED $bumpmap: "$bumpmap" "dev/flat_normal"

	// TF2_UNSUPPORTED %keywords: "%keywords" "shatter"

	"$translucent" 1
	"$nocull" 1

	"$allowDiffuseModulation" 1
	// TF2_UNSUPPORTED $detailcoordsfromvertex: "$detailcoordsfromvertex" 1

	"$envmap" "env_cubemap"

	//"$fresnelranges" "[.5 .15 1]"
	//"$envmapfresnel" "1"
	//"$envmaptint" "[.24 .33 .3]"
	//"$envmaptint" "[.5 .5 .5]"

	"$surfaceprop" "glass_breakable"

	"Proxies"
	{
		// TF2_UNSUPPORTED BreakableSurface: "BreakableSurface"
		// TF2_UNSUPPORTED BreakableSurface: {
		// TF2_UNSUPPORTED block: }
	}
}

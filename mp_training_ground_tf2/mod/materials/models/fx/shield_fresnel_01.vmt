"UnlitTwoTexture"
{
	"$nocull" "1"
	"$nodecal" "1"
	"$fresnel" 1
	"$fresnelsharpness1" 1
	"$fresnelouterstrength1" 1
	"$fresnelinnerstrength1" 10
	"$additive" "1"
	"$no_fullbright" 1
	"$vertexcolor" 1
	"$vertexalpha" 1
	"$model" "1"
	"$translucent" 1
	"$color2" "[1 1 1]"
	"$basetexture" "effects\caustic_water_01"
	"$texture2" "effects\caustic_water_01"
	"$color" "[0.43 0.43 0.43]"
	"$color2" "[0.72 2 0.71]"

	"Proxies"
	{
		"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" .1
			"texturescrollangle" -40
		}
		"TextureScroll"
		{
			"texturescrollvar" "$texture2transform"
			"texturescrollrate" .2
			"texturescrollangle" 90
		}
	}
}
"UnlitTwoTexture"
{
	"$basetexture" "effects\caustic_water_01"
	"$texture2" "effects\caustic_water_01"
	"$nodecal" "1"
	"$fresnel" 1
	"$fresnelsharpness1" 0
	"$fresnelouterstrength1" 1
	"$fresnelinnerstrength1" 10
	"$layeralpha1" "1"
	"$layeralpha2" ".75"
	"$addlayers" 1
	"$screenspacecoordssquare1" 1
	"$screenspacecoordssquare2" 1
	"$additive" "1"
	"$vertexalpha" 1
	"$model" "1"
	"$translucent" 1

	"Proxies"
	{
		"AnimatedTexture"
		{
			"animatedtexturevar" "$texture2"
			"animatedtextureframenumvar" "$frame2"
			"animatedtextureframerate" "30"
		}
		"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" .1
			"texturescrollangle" 145
			"texturescale" .5
		}
		"TextureScroll"
		{
			"texturescrollvar" "$texture2transform"
			"texturescrollrate" 10
			"texturescrollangle" 45
			"texturescale" 2
		}
	}
}
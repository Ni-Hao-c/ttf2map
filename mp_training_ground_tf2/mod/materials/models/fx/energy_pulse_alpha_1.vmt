"UnlitTwoTexture"
{
	"$nodecal" "1"
	"$allowoverbright" 1
	"$additive" "1"
	"$no_fullbright" 1
	"$vertexcolor" 1
	"$vertexalpha" 1
	"$model" "1"
	"$translucent" 1
	"$nocull" "1"
	"$color2" "[3 3 3]"
	"$fresnel" 1
	"$fresnelsharpness1" 1
	"$fresnelouterstrength1" 10
	"$fresnelinnerstrength1" 1
	"$addlayers" 1
	"$basetexture" "effects\tvscreen_noise001b"
	"$texture2" "effects\tvscreen_noise001b"
	"$color" "[0.43 0.43 0.43]"
	"$color2" "[0.72 2 0.71]"

	"Proxies"
	{
		"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" .1
			"texturescrollangle" -90
		}
		"TextureScroll"
		{
			"texturescrollvar" "$texture2transform"
			"texturescrollrate" .5
			"texturescrollangle" 45
		}
	}
}
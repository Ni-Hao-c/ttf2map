"UnlitTwoTexture"
{
	"$surfaceprop" "metal"
	//"$basetexture" "models\titans\titan_ar_marker\titan_ar_marker_col"
	//$basetexture "dev\noise_post"
	//"$basetexture" "effects\tvscreen_noise001b"
	"$basetexture" "effects\dev_scanline_small"
	//"$basetexture" "effects\electric_anim"
	//"$basetexture" "effects\electric_anim"
	"$texture2" "models\robots\spactre\spectre_body_corporate_col"


	$alpha 1

	$translucent 1
	$screenblend 1

	$screenspacecoordssquare1 1
	//$screenspacecoordssquare2 1

	//$layercolor1 "[0.1 1.5 0.1]"
	$layeralpha1 "0.25"
	//$layercolor2 "[1 1 1]"
	$layeralpha2 "1"
	$addlayers 1

	$fresnel 1
	$fresnelsharpness1 0
	$fresnelouterstrength1 1
	$fresnelinnerstrength1 0

	$fresnel2 1
	$fresnelsharpness2 1
	$fresnelouterstrength2 2
	$fresnelinnerstrength2 0



	Proxies
	{
		"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" .25
			"texturescrollangle" -90
			"texturescale"	4
		}

		"AnimatedTexture"
		{
			"animatedtexturevar" "$basetexture"
			"animatedtextureframenumvar" "$frame"
			"animatedtextureframerate" 30 
		}
		
	}
}